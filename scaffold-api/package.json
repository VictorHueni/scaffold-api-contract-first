{
  "name": "scaffold-api-contract-first",
  "version": "1.0.0",
  "description": "API-first scaffold with contract-driven tooling",
  "private": true,
  "scripts": {
    "------- SPEC -------": "",
    "bundle": "scalar document bundle specs/order-api.yaml -o specs/order-api.bundled.yaml",
    "validate": "scalar document validate specs/order-api.yaml",

    "------- QUALITY -------": "",
    "lint": "spectral lint specs/order-api.yaml --ruleset rules/.spectral.yaml --ignore-unknown-format",
    "lint:bad": "spectral lint specs/order-api-bad.yaml --ruleset rules/.spectral.yaml --ignore-unknown-format",

    "------- DEV -------": "",
    "mock": "prism mock specs/order-api.bundled.yaml --port 4010",
    "mock:dynamic": "prism mock -d specs/order-api.bundled.yaml --port 4010",
    "types": "openapi-typescript specs/order-api.yaml -o generated/api-types.d.ts --read-write-markers",
    "docs": "scalar document serve specs/order-api.bundled.yaml --port 8081 --watch",
    "docs:build": "scalar document bundle specs/order-api.bundled.yaml -o docs/scalar-reference.html",

    "------- TEST -------": "",
    "test:contract": "docker run --rm --network host -v $(pwd):/app schemathesis/schemathesis run /app/specs/order-api.bundled.yaml --base-url http://localhost:4010 --checks all --stateful=links --hypothesis-max-examples=100 --set-header 'X-API-Key: test-key'",
    "test:contract:negative": "docker run --rm --network host -v $(pwd):/app schemathesis/schemathesis run /app/specs/order-api.bundled.yaml --base-url http://localhost:4010 --checks all --mode=negative --hypothesis-max-examples=50 --set-header 'X-API-Key: test-key'",
    "test:hurl": "hurl --test tests/**/*.hurl",
    "test:hurl:docker": "docker run --rm --network host -v $(pwd):/app ghcr.io/orange-opensource/hurl:latest --test /app/tests/**/*.hurl",
    "breaking": "oasdiff breaking specs/order-api.yaml specs/order-api-v2.yaml --fail-on ERR",
    "breaking:docker": "docker run --rm -v $(pwd):/app tufin/oasdiff breaking /app/specs/order-api.yaml /app/specs/order-api-v2.yaml --fail-on ERR",

    "------- BACKEND -------": "",
    "stubs": "openapi-generator-cli generate -i specs/order-api.bundled.yaml -g spring -o generated/server-spring --additional-properties=interfaceOnly=true,useSpringBoot3=true --skip-validate-spec",

    "------- PRECHECK -------": "",
    "precheck": "npm run bundle && npm run lint"
  },
  "devDependencies": {
    "@stoplight/prism-cli": "^5",
    "@stoplight/spectral-cli": "^6",
    "@stoplight/spectral-owasp-ruleset": "^2",
    "@scalar/cli": "^1",
    "openapi-typescript": "^7",
    "openapi-fetch": "^0.17",
    "@openapitools/openapi-generator-cli": "^2",
    "typescript": "^5"
  }
}
